# Haggle.ai Configuration
# Copy this file to .env and update with your settings

# ============================================
# LLM ENGINE SELECTION
# ============================================
# Choose between "ollama" or "openai"
ENGINE=ollama

# ============================================
# OLLAMA CONFIGURATION (if ENGINE=ollama)
# ============================================
# Make sure Ollama is running locally with: ollama serve
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Alternative models you can try:
# OLLAMA_MODEL=llama3:8b
# OLLAMA_MODEL=llama3:70b
# OLLAMA_MODEL=mistral:7b
# OLLAMA_MODEL=codellama:7b

# ============================================
# OPENAI CONFIGURATION (if ENGINE=openai)
# ============================================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Alternative OpenAI models:
# OPENAI_MODEL=gpt-4o
# OPENAI_MODEL=gpt-3.5-turbo

# ============================================
# DATABASE CONFIGURATION
# ============================================
# SQLite database file location (relative to project root)
DATABASE_PATH=haggle_ai.db

# ============================================
# APPLICATION SETTINGS
# ============================================
# Debug mode (set to true for development)
DEBUG=false

# Default negotiation settings
DEFAULT_SERVICE_TYPE=SaaS Subscription
DEFAULT_RELATIONSHIP=1-3 Years

# ============================================
# VOICE TRANSCRIPTION (Optional)
# ============================================
ENABLE_VOICE=false
# Model sizes: tiny, base, small, medium, large-v3
WHISPER_MODEL_SIZE=base

# ============================================
# ADVANCED SETTINGS (Optional)
# ============================================
# Request timeout for LLM calls (seconds)
LLM_TIMEOUT=60

# Maximum tokens for LLM responses
MAX_TOKENS=2000

# Temperature for LLM generation (0.0-1.0)
LLM_TEMPERATURE=0.7

# Enable experimental features
ENABLE_MULTI_AGENT_DEBATE=false
ENABLE_MARKET_BENCHMARKS=false
